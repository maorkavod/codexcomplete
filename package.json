{
  "name": "codexcomplete",
  "displayName": "CodexComplete",
  "description": "Copilot-style inline autocomplete powered by OpenAI Codex profiles.",
  "version": "0.0.15",
  "publisher": "MaorKavod",
  "license": "MIT",
  "icon": "media/marketplace-icon.png",
  "homepage": "https://github.com/maorkavod/codexcomplete#readme",
  "author": {
    "name": "Maor Kavod",
    "email": "Maor.kavod@gmail.com"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "autocomplete",
    "ai",
    "openai",
    "codex",
    "inline-completion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/maorkavod/codexcomplete"
  },
  "bugs": {
    "url": "https://github.com/maorkavod/codexcomplete/issues"
  },
  "files": [
    "out/**/*.js",
    "media/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codexComplete.setApiKey",
    "onCommand:codexComplete.completeNow",
    "onCommand:codexComplete.openPanel",
    "onCommand:codexComplete.openLogs",
    "onCommand:codexComplete.openLogsTerminal",
    "onView:codexComplete.sidebarView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexCompleteContainer",
          "title": "CodexComplete",
          "icon": "media/codexcomplete-activity.svg"
        }
      ]
    },
    "views": {
      "codexCompleteContainer": [
        {
          "id": "codexComplete.sidebarView",
          "name": "CodexComplete",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codexComplete.setApiKey",
        "title": "CodexComplete: Set OpenAI API Key"
      },
      {
        "command": "codexComplete.completeNow",
        "title": "CodexComplete: Complete Now"
      },
      {
        "command": "codexComplete.openPanel",
        "title": "CodexComplete: Open Diagnostics Panel"
      },
      {
        "command": "codexComplete.openLogs",
        "title": "CodexComplete: Open Logs"
      },
      {
        "command": "codexComplete.openLogsTerminal",
        "title": "CodexComplete: Open Logs Terminal"
      }
    ],
    "configuration": {
      "title": "CodexComplete",
      "properties": {
        "codexComplete.model": {
          "type": "string",
          "default": "gpt-5.3-codex",
          "markdownDescription": "Model used for completions. Default is gpt-5.3-codex. You can pick any model from the CodexComplete GUI dropdown (loaded from your OpenAI account), or type a model id manually."
        },
        "codexComplete.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 120000,
          "markdownDescription": "Request timeout in milliseconds."
        },
        "codexComplete.debounceMs": {
          "type": "number",
          "default": 120,
          "minimum": 0,
          "maximum": 2000,
          "markdownDescription": "Debounce before sending autocomplete request."
        },
        "codexComplete.maxContextChars": {
          "type": "number",
          "default": 9000,
          "minimum": 500,
          "maximum": 20000,
          "markdownDescription": "Maximum combined prefix/suffix characters to send for context."
        },
        "codexComplete.enableInline": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable inline ghost-text autocomplete suggestions."
        },
        "codexComplete.includeLeadingLogicComment": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When enabled, completions must start with a comment line that briefly explains the logic."
        },
        "codexComplete.indentMode": {
          "type": "string",
          "enum": [
            "editor",
            "language",
            "smart"
          ],
          "default": "smart",
          "markdownDescription": "Indent strategy for completion insertion. smart = adapt to file/editor context."
        },
        "codexComplete.inlineMaxLines": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 64,
          "markdownDescription": "Maximum lines allowed for inline completion candidates."
        },
        "codexComplete.inlineMaxChars": {
          "type": "number",
          "default": 700,
          "minimum": 32,
          "maximum": 4000,
          "markdownDescription": "Maximum characters allowed for inline completion candidates."
        },
        "codexComplete.strictInlineMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Use stricter filtering and prompting for concise, deterministic inline completions."
        },
        "codexComplete.dailyTokenLimit": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "maximum": 5000000,
          "markdownDescription": "Maximum total tokens allowed per local calendar day. Set null for no limit."
        },
        "codexComplete.ignorePathRegexes": {
          "type": "array",
          "default": [
            "env"
          ],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Additional regex patterns for file paths to ignore for completion requests. Matching is done against the full file path."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run build:webview && tsc -p ./",
    "test:pipeline": "npm run compile && node --test out/aiResponsePipeline.spec.js out/insertionFormatter.spec.js",
    "watch": "npm run build:webview && tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "build:webview": "node ./scripts/build-webview.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
